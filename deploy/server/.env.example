# Copy to .env and fill in — .env must never be committed to git.

# Postgres connection string
DATABASE_URL=postgresql://procmaster:CHANGE_ME@localhost:5432/procmaster

# Port the Node API listens on (Caddy proxies 443 → here)
PORT=3000

# Azure AD tenant — used to verify Microsoft 365 access tokens.
# Get this from Azure portal → Entra ID → Overview.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure AD app registration client id — same app as the ProMaster SP integration.
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Comma-separated allowed origins for CORS.
# In production this is https://procmaster.local and any user-machine hostname.
CORS_ORIGINS=https://procmaster.local,http://localhost:8123

# Optional: cap how many rows a single list request can return.
MAX_PAGE_SIZE=500

# Log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
