# Caddy 2 reverse proxy for ProMaster.
# Auto-HTTPS is on by default. For internal hostnames Caddy issues
# its own cert from a local CA; install that CA on client machines.
#
# Location on disk:
#   Ubuntu   /etc/caddy/Caddyfile   (systemctl reload caddy)
#   Windows  C:\Program Files\Caddy\Caddyfile   (Restart-Service caddy)

procmaster.local {
    # Internal-only cert. Delete this line and Caddy will fetch a
    # real Let's Encrypt cert IF the hostname resolves publicly.
    tls internal

    encode zstd gzip

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000"
        X-Content-Type-Options    "nosniff"
        Referrer-Policy           "strict-origin-when-cross-origin"
        X-Frame-Options           "DENY"
        -Server
    }

    # API traffic → Node service on localhost:3000
    reverse_proxy 127.0.0.1:3000

    log {
        output file /var/log/caddy/procmaster.log {
            roll_size 50MiB
            roll_keep 10
        }
        format json
    }
}
